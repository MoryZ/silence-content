{
  "rules": [
    {
      "name": "underscore_to_camel_case",
      "type": "field_transform",
      "condition": "target.fieldName.contains('_')",
      "actions": [
        {
          "type": "regex_replace",
          "config": {
            "pattern": "_([a-z])",
            "replacement": "$1"
          }
        },
        {
          "type": "expression", 
          "config": {
            "expression": "target.fieldName.substring(0, 1).toUpperCase() + target.fieldName.substring(1)"
          }
        }
      ],
      "priority": 10,
      "enabled": true
    },
    {
      "name": "remove_is_prefix",
      "type": "field_transform", 
      "condition": "target.fieldType == 'boolean' && target.fieldName.startsWith('is_')",
      "actions": [
        {
          "type": "regex_replace",
          "config": {
            "pattern": "^is_",
            "replacement": ""
          }
        },
        {
          "type": "set_property",
          "config": {
            "property": "javaType",
            "value": "Boolean"
          }
        }
      ],
      "priority": 20,
      "enabled": true
    }
  ]
}