<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.old.silence.content.infrastructure.persistence.tournament.dao.TournamentTaskDao">

    <update id="updateStatusAsLock">
        UPDATE tournament_task
        SET status = #{newStatus}
        where id = #{id}
        and status = #{oldStatus}
    </update>

</mapper>
