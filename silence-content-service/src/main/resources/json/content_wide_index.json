{
  "settings": {
    "number_of_shards": 3,
    "number_of_replicas": 1,
    "analysis": {
      "analyzer": {
        "ik_smart": {
          "type": "text",
          "analyzer": "ik_smart"
        },
        "ik_max_word": {
          "type": "text",
          "analyzer": "ik_max_word"
        }
      }
    }
  },
  "mappings": {
    "properties": {
      "title": {"type": "text", "analyzer": "ik_max_word"},
      "type": {"type": "integer"},
      "status": {"type": "integer"},
      "author": {"type": "text", "analyzer": "ik_max_word"},
      "publishedAt": {"type": "date", "format": "yyyy-MM-dd'T'HH:mm:ssZ"},
      "contentCode": {"type": "keyword"},
      "coverImageReference": {"type": "keyword"},
      "coverImageReferenceMode": {"type": "integer"},
      "contentReferenceMode": {"type": "integer"},
      "contentReference": {"type": "text"},
      "keywords": {"type": "text"},
      "tenantId": {"type": "integer"},
      "auditCode": {"type": "keyword"},
      "taskCode": {"type": "keyword"},
      "parentId": {"type": "long"},
      "rootId": {"type": "long"},
      "stickyTop": {"type": "boolean"},
      "stickyTopAt": {"type": "date", "format": "yyyy-MM-dd'T'HH:mm:ssZ"},
      "stickyTopExpiredAt": {"type": "date", "format": "yyyy-MM-dd'T'HH:mm:ssZ"},
      "disclosure": {"type": "boolean"},
      "leaf": {"type": "boolean"},
      "attributes": {"type": "object"},
      "businessStatus": {"type": "integer"},
      "source": {"type": "keyword"},
      "codeDisplayRequired": {"type": "boolean"},
      "needInternalReview": {"type": "boolean"},
      "expiredAt": {"type": "date", "format": "yyyy-MM-dd'T'HH:mm:ssZ"},
      "createdDate": {"type": "date", "format": "yyyy-MM-dd'T'HH:mm:ssZ"},
      "lastModifiedDate": {"type": "date", "format": "yyyy-MM-dd'T'HH:mm:ssZ"},
      "createdBy": {"type": "text", "analyzer": "chinese_analyzer"},
      "lastModifiedBy": {"type": "text", "analyzer": "chinese_analyzer"},
      "previewAccumulation": {"type": "long"},
      "likeAccumulation": {"type": "long"},
      "forwardAccumulation": {"type": "long"},

      "article": {
        "properties": {
          "summary": {"type": "text"},
          "reprintDeclaration": {"type": "text"},
          "appliedToScenarioType": {"type": "integer"},
          "publisher": {"type": "keyword"},
          "smallImageUrlReference": {"type": "keyword"}
        }
      },
      "live": {
        "properties": {
          "roomId": {"type": "integer"},
          "startDate": {"type": "date", "format": "yyyy-MM-dd'T'HH:mm:ssZ"},
          "finishDate": {"type": "date", "format": "yyyy-MM-dd'T'HH:mm:ssZ"},
          "activeDate": {"type": "date", "format": "yyyy-MM-dd'T'HH:mm:ssZ"},
          "endDate": {"type": "date", "format": "yyyy-MM-dd'T'HH:mm:ssZ"},
          "liveStatus": {"type": "integer"},
          "tabularImageReference": {"type": "keyword"},
          "tabularImageReferenceMode": {"type": "integer"}
        }
      },
      "video": {
        "properties": {
          "description": {"type": "text"},
          "duration": {"type": "integer"},
          "width": {"type": "integer"},
          "height": {"type": "integer"},
          "verticalCoverImageReference": {"type": "keyword"},
          "scriptFilename": {"type": "keyword"},
          "scriptFileKey": {"type": "keyword"},
          "videoName": {"type": "keyword"}
        }
      },
      "product_term": {
        "properties": {
          "productCode": {"type": "keyword"},
          "onSaleAt": {"type": "date", "format": "yyyy-MM-dd'T'HH:mm:ssZ"},
          "offSaleAt": {"type": "date", "format": "yyyy-MM-dd'T'HH:mm:ssZ"},
          "displayOrder": {"type": "integer"}
        }
      },

      "tags": {
        "type": "nested",
        "properties": {
          "tagId": {"type": "keyword"},
          "tagCode": {"type": "keyword"},
          "tagName": {"type": "keyword"},
          "tagSort": {"type": "integer"},
          "tagType": {"type": "keyword"}
        }
      }
    }
  }
}