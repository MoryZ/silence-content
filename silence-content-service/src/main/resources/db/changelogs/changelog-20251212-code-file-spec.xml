<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.1.xsd">

    <changeSet id="20251212-add-code-file-spec-table" author="moryzang">
        <comment>添加代码文件规格配置表，用于集中管理代码生成元数据</comment>

        <createTable tableName="cg_code_file_spec" remarks="代码文件规格表">
            <column name="id" type="BIGINT UNSIGNED" remarks="主键">
                <constraints nullable="false" primaryKey="true"/>
            </column>
            <column name="template_name" type="VARCHAR(100)" remarks="模板文件名（如 command.ftl）">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="module_type" type="VARCHAR(50)" remarks="所属模块类型（CONSOLE/SERVICE/SERVICE_API/ENUM）">
                <constraints nullable="false"/>
            </column>
            <column name="package_suffix" type="VARCHAR(200)" remarks="包名后缀（如 .api.dto）">
                <constraints nullable="false"/>
            </column>
            <column name="relative_dir" type="VARCHAR(200)" remarks="相对输出目录（如 api/dto）">
                <constraints nullable="false"/>
            </column>
            <column name="file_name_suffix" type="VARCHAR(100)" remarks="文件名后缀（如 Command, Query）">
                <constraints nullable="false"/>
            </column>
            <column name="file_type_tag" type="VARCHAR(50)" remarks="文件类型标签（dto, vo, service 等，用于预览分组）">
                <constraints nullable="false"/>
            </column>
            <column name="generation_condition" type="VARCHAR(50)" remarks="生成条件（ALWAYS/HAS_ANY_ENDPOINT/HAS_ENDPOINT）">
                <constraints nullable="false"/>
            </column>
            <column name="endpoint_names" type="VARCHAR(500)" remarks="触发生成的端点名称（JSON数组），用于 HAS_ENDPOINT 条件">
                <constraints nullable="true"/>
            </column>
            <column name="display_name" type="VARCHAR(100)" remarks="显示名称">
                <constraints nullable="true"/>
            </column>
            <column name="description" type="TEXT" remarks="描述文本">
                <constraints nullable="true"/>
            </column>
            <column name="version" type="INT" remarks="版本号">
                <constraints nullable="false"/>
            </column>
            <column name="is_enabled" type="BOOLEAN" remarks="是否启用">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" remarks="创建人员" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="created_date" remarks="创建时间" type="TIMESTAMP(3)">
                <constraints nullable="false"/>
            </column>
            <column name="updated_by" remarks="更新人员" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="updated_date" remarks="最后更新时间" type="TIMESTAMP(3)">
                <constraints nullable="true"/>
            </column>
        </createTable>

        <!-- 创建索引 -->
        <createIndex indexName="idx_module_type" tableName="cg_code_file_spec">
            <column name="module_type"/>
        </createIndex>

        <createIndex indexName="idx_generation_condition" tableName="cg_code_file_spec">
            <column name="generation_condition"/>
        </createIndex>

        <addUniqueConstraint
                tableName="cg_code_file_spec"
                columnNames="module_type,template_name"
                constraintName="uk_module_template"/>
    </changeSet>



</databaseChangeLog>
