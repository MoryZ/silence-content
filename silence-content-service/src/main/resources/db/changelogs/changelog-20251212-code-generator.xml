<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.9.xsd">

    <property name="autoIncrement" value="true" dbms="mysql" />
    
    <changeSet author="moryzang" id="20251212-code-generator-tables">

        <!-- 表元数据存储表 -->
        <createTable remarks="代码生成器-表元数据" tableName="code_table_meta">
            <column autoIncrement="${autoIncrement}" name="id" remarks="主键" type="BIGINT UNSIGNED">
                <constraints nullable="false" primaryKey="true" />
            </column>
            <column name="table_name" remarks="表名" type="VARCHAR(100)">
                <constraints nullable="false" unique="true" />
            </column>
            <column name="schema_name" remarks="数据库Schema" type="VARCHAR(50)">
                <constraints nullable="true" />
            </column>
            <column name="comment" remarks="表注释" type="VARCHAR(500)">
                <constraints nullable="true" />
            </column>
            <column name="detail" remarks="完整表信息JSON(包含列、索引、外键、主键)" type="LONGTEXT">
                <constraints nullable="false" />
            </column>
            <column name="created_at" remarks="创建时间" type="TIMESTAMP(3)">
                <constraints nullable="false" />
                <defaultValueCurrentTimestampChangeType>TIMESTAMP(3)</defaultValueCurrentTimestampChangeType>
            </column>
            <column name="updated_at" remarks="更新时间" type="TIMESTAMP(3)">
                <constraints nullable="false" />
                <defaultValueCurrentTimestampChangeType>TIMESTAMP(3)</defaultValueCurrentTimestampChangeType>
            </column>
            <column name="created_by" remarks="创建人" type="VARCHAR(100)">
                <constraints nullable="true" />
            </column>
            <column name="updated_by" remarks="更新人" type="VARCHAR(100)">
                <constraints nullable="true" />
            </column>
        </createTable>
        
        <createIndex indexName="idx_code_table_meta_table_name" tableName="code_table_meta">
            <column name="table_name" />
        </createIndex>
        <createIndex indexName="idx_code_table_meta_created_at" tableName="code_table_meta">
            <column name="created_at" />
        </createIndex>

        <!-- API文档表 -->
        <createTable remarks="代码生成器-API文档" tableName="code_api_document">
            <column autoIncrement="${autoIncrement}" name="id" remarks="主键" type="BIGINT UNSIGNED">
                <constraints nullable="false" primaryKey="true" />
            </column>
            <column name="table_name" remarks="对应的表名" type="VARCHAR(100)">
                <constraints nullable="false" />
            </column>
            <column name="api_name" remarks="API文档名称" type="VARCHAR(100)">
                <constraints nullable="true" />
            </column>
            <column name="detail" remarks="完整API文档JSON(包含endpoints、parameters、responses)" type="LONGTEXT">
                <constraints nullable="false" />
            </column>
            <column name="created_at" remarks="创建时间" type="TIMESTAMP(3)">
                <constraints nullable="false" />
                <defaultValueCurrentTimestampChangeType>TIMESTAMP(3)</defaultValueCurrentTimestampChangeType>
            </column>
            <column name="updated_at" remarks="更新时间" type="TIMESTAMP(3)">
                <constraints nullable="false" />
                <defaultValueCurrentTimestampChangeType>TIMESTAMP(3)</defaultValueCurrentTimestampChangeType>
            </column>
            <column name="created_by" remarks="创建人" type="VARCHAR(100)">
                <constraints nullable="true" />
            </column>
            <column name="updated_by" remarks="更新人" type="VARCHAR(100)">
                <constraints nullable="true" />
            </column>
        </createTable>
        
        <createIndex indexName="idx_code_api_document_table_name" tableName="code_api_document">
            <column name="table_name" />
        </createIndex>
        <createIndex indexName="idx_code_api_document_created_at" tableName="code_api_document">
            <column name="created_at" />
        </createIndex>

        <!-- 代码生成历史表 -->
        <createTable remarks="代码生成器-生成历史" tableName="code_generation_history">
            <column autoIncrement="${autoIncrement}" name="id" remarks="主键" type="BIGINT UNSIGNED">
                <constraints nullable="false" primaryKey="true" />
            </column>
            <column name="table_name" remarks="表名" type="VARCHAR(100)">
                <constraints nullable="false" />
            </column>
            <column name="generation_type" remarks="生成类型(table/api/entity/controller/service等)" type="VARCHAR(50)">
                <constraints nullable="false" />
            </column>
            <column name="version" remarks="版本号" type="INT UNSIGNED">
                <constraints nullable="false" />
            </column>
            <column name="generated_code" remarks="生成的代码" type="LONGTEXT">
                <constraints nullable="true" />
            </column>
            <column name="generation_metadata" remarks="生成元数据JSON(参数、配置等)" type="LONGTEXT">
                <constraints nullable="true" />
            </column>
            <column name="status" remarks="状态(success/failed/processing)" type="VARCHAR(20)">
                <constraints nullable="false" />
            </column>
            <column name="error_message" remarks="错误信息" type="VARCHAR(500)">
                <constraints nullable="true" />
            </column>
            <column name="created_at" remarks="创建时间" type="TIMESTAMP(3)">
                <constraints nullable="false" />
                <defaultValueCurrentTimestampChangeType>TIMESTAMP(3)</defaultValueCurrentTimestampChangeType>
            </column>
            <column name="created_by" remarks="创建人" type="VARCHAR(100)">
                <constraints nullable="true" />
            </column>
        </createTable>
        
        <createIndex indexName="idx_code_generation_history_table_name" tableName="code_generation_history">
            <column name="table_name" />
        </createIndex>
        <createIndex indexName="idx_code_generation_history_type" tableName="code_generation_history">
            <column name="generation_type" />
        </createIndex>
        <createIndex indexName="idx_code_generation_history_created_at" tableName="code_generation_history">
            <column name="created_at" />
        </createIndex>

    </changeSet>

</databaseChangeLog>
