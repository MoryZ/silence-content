<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.1.xsd">

    <changeSet id="20260412-add-tournament-task-dependency-columns" author="moryzang">
        <comment>在 tournament_task 表中增加任务依赖字段，显式表达前置任务关系</comment>

        <preConditions onFail="MARK_RAN">
            <tableExists tableName="tournament_task"/>
        </preConditions>

        <addColumn tableName="tournament_task">
            <column name="depends_on_task_id" type="BIGINT UNSIGNED" remarks="前置任务ID"/>
            <column name="depends_on_status" type="VARCHAR(20)" defaultValue="SUCCESS" remarks="前置任务需要达到的状态">
                <constraints nullable="false"/>
            </column>
        </addColumn>

        <createIndex indexName="idx_depends_on_task" tableName="tournament_task">
            <column name="depends_on_task_id"/>
            <column name="depends_on_status"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
