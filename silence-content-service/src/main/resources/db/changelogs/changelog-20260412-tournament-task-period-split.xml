<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.1.xsd">

    <changeSet id="20260412-split-tournament-task-period" author="moryzang">
        <comment>将 tournament_task.period_no 拆分为 stage_no/segment_no/cycle_no 三字段</comment>

        <preConditions onFail="MARK_RAN">
            <tableExists tableName="tournament_task"/>
            <columnExists tableName="tournament_task" columnName="period_no"/>
        </preConditions>

        <addColumn tableName="tournament_task">
            <column name="stage_no" type="INT" remarks="场次号"/>
            <column name="segment_no" type="INT" remarks="片号"/>
            <column name="cycle_no" type="INT" remarks="周期号"/>
        </addColumn>

        <!-- 旧数据迁移：默认将 period_no 同步到三个新字段，后续由业务逐步精细化填充 -->
        <sql>
            UPDATE tournament_task
            SET stage_no = period_no,
                segment_no = period_no,
                cycle_no = period_no
            WHERE period_no IS NOT NULL;
        </sql>

        <dropColumn tableName="tournament_task" columnName="period_no"/>

        <createIndex indexName="idx_task_stage" tableName="tournament_task">
            <column name="tournament_id"/>
            <column name="stage_no"/>
            <column name="status"/>
        </createIndex>

        <createIndex indexName="idx_task_segment" tableName="tournament_task">
            <column name="tournament_id"/>
            <column name="segment_no"/>
            <column name="status"/>
        </createIndex>

        <createIndex indexName="idx_task_cycle" tableName="tournament_task">
            <column name="tournament_id"/>
            <column name="cycle_no"/>
            <column name="status"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
