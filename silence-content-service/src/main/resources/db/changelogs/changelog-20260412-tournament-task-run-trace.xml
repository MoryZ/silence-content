<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.1.xsd">

    <changeSet id="20260412-add-tournament-task-run-trace" author="moryzang">
        <comment>在 tournament_task 表中增加 run_trace_id 字段用于任务链路追踪</comment>

        <preConditions onFail="MARK_RAN">
            <tableExists tableName="tournament_task"/>
        </preConditions>

        <addColumn tableName="tournament_task">
            <column name="run_trace_id" type="VARCHAR(64)" remarks="任务执行链路追踪ID"/>
        </addColumn>

        <createIndex indexName="idx_tournament_task_run_trace" tableName="tournament_task">
            <column name="run_trace_id"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>