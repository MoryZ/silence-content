sequenceDiagram
    actor Timer as 定时系统
    participant Dispatcher as TaskDispatcherService
    participant TaskTable as tournament_task
    participant StageHandler as StageSettleTaskHandlerStrategy
    participant ChallengeSvc as ChallengeRecordService
    participant ScoreRecord as tournament_score_record
    participant SegmentHandler as SegmentSettleTaskHandlerStrategy
    participant CycleHandler as CycleSettleTaskHandlerStrategy
    participant GroupService as GroupService
    participant RankingCache as Redis缓存
    participant Listener as RewardDispatchListener
    participant MQ as MQ生产者

    Timer->>Dispatcher: 每 3-5 秒触发 dispatchPendingTasks()

    Dispatcher->>TaskTable: SELECT * FROM tournament_task WHERE status IN (PENDING, FAILED) AND trigger_time <= NOW() LIMIT batch_size
    TaskTable-->>Dispatcher: taskList[]

    loop 对每个待执行任务
        Dispatcher->>TaskTable: 检查依赖是否满足
        TaskTable-->>Dispatcher: 依赖检查结果

        alt 依赖不满足
            Dispatcher->>Dispatcher: 保持 PENDING
        else 依赖满足
            Dispatcher->>TaskTable: UPDATE status = RUNNING

            alt task.task_type == STAGE_SETTLE
                Dispatcher->>StageHandler: execute(task)
                StageHandler->>ChallengeSvc: getCompletedChallenges(stageNo)
                ChallengeSvc-->>StageHandler: challengeList[]
                StageHandler->>StageHandler: 计算 STAGE 分数
                StageHandler->>ScoreRecord: INSERT STAGE score
                ScoreRecord-->>StageHandler: success
                StageHandler->>TaskTable: UPDATE status = SUCCESS
                StageHandler-->>Dispatcher: success
                Dispatcher->>TaskTable: appendNextTask() 插入 SEGMENT task
            else task.task_type == SEGMENT_SETTLE
                Dispatcher->>SegmentHandler: execute(task)
                SegmentHandler->>ScoreRecord: getStageScores(segment_range)
                ScoreRecord-->>SegmentHandler: scoreList[]
                SegmentHandler->>SegmentHandler: 计算 SEGMENT 分数
                SegmentHandler->>ScoreRecord: INSERT SEGMENT score
                ScoreRecord-->>SegmentHandler: success
                SegmentHandler->>TaskTable: UPDATE status = SUCCESS
                SegmentHandler-->>Dispatcher: success
                Dispatcher->>TaskTable: appendNextTask() 插入 CYCLE task
            else task.task_type == CYCLE_SETTLE
                Dispatcher->>CycleHandler: execute(task)
                CycleHandler->>ScoreRecord: getSegmentScores(cycle_range)
                ScoreRecord-->>CycleHandler: scoreList[]
                CycleHandler->>CycleHandler: 计算 CYCLE 分数，回写总分
                CycleHandler->>ScoreRecord: INSERT CYCLE score
                ScoreRecord-->>CycleHandler: success
                alt 不是最后一个 cycle
                    CycleHandler->>GroupService: 重新分组
                    GroupService-->>CycleHandler: newGroupList
                    CycleHandler->>RankingCache: refreshRankingCache()
                    RankingCache-->>CycleHandler: success
                else 最后一个 cycle 的最后一个场次
                    CycleHandler->>ScoreRecord: getAllParticipants(config)
                    ScoreRecord-->>CycleHandler: participantList[]
                    CycleHandler->>CycleHandler: 计算全国排名 + 组内排名
                    CycleHandler->>MQ: 发送奖励发放事件
                    MQ-->>CycleHandler: success
                end
                CycleHandler->>TaskTable: UPDATE status = SUCCESS
                CycleHandler-->>Dispatcher: success
            end
        end

        Dispatcher->>TaskTable: 检查赛事是否全部完成
        TaskTable-->>Dispatcher: unfinished_count

        alt unfinished_count == 0
            Dispatcher->>Listener: emitRewardDispatchEventIfReady()
            Listener->>MQ: sendWithTag(topic, tag, message)
            MQ-->>Listener: success
        end
    end
    Dispatcher-->>Timer: 本轮调度完成
