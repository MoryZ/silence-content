sequenceDiagram
    actor Timer as 定时系统
    participant CacheJob as DailyCacheRebuildJob
    participant ConfigClient as TournamentConfigClient
    participant ParticipantClient as TournamentParticipationRecordClient
    participant ConfigDB as tournament_config
    participant ParticipantDB as tournament_participation_record
    participant Redis as Redis缓存

    Timer->>CacheJob: 每日凌晨触发 jobExecute()
    CacheJob->>ConfigClient: query(pageSize=1000)
    ConfigClient->>ConfigDB: SELECT * FROM tournament_config LIMIT 1000
    ConfigDB-->>ConfigClient: configList[]
    ConfigClient-->>CacheJob: TournamentConfigView[]

    loop 每个赛事配置
        CacheJob->>ParticipantClient: query(eventGameId=?, status=REGISTERED)
        ParticipantClient->>ParticipantDB: SELECT * FROM tournament_participation_record WHERE event_game_id = ? AND status = REGISTERED LIMIT 1000
        ParticipantDB-->>ParticipantClient: participantList[]
        ParticipantClient-->>CacheJob: TournamentParticipationRecordView[]
        CacheJob->>CacheJob: 按 totalScore 降序排序
        CacheJob->>CacheJob: 生成排行榜列表
        CacheJob->>Redis: SET ranking:list:{eventGameId} rankings_json PX 86400000
        Redis-->>CacheJob: success
    end

    CacheJob-->>Timer: ExecuteResult
