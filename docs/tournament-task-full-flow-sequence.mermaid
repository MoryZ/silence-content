sequenceDiagram
    autonumber
    participant Scheduler as 定时调度
    participant ScanJob as TournamentStartScanJob
    participant ConfigRepo as TournamentConfigRepository
    participant TaskRepo as TournamentTaskRepository
    participant DispatchJob as TournamentTaskDispatchJob
    participant DispatchSvc as TaskDispatcherService
    participant HandlerFactory as TournamentTaskHandlerFactory
    participant RegHandler as RegistrationEndTaskHandler
    participant StageHandler as StageSettleTaskHandler
    participant SegmentHandler as SegmentSettleTaskHandler
    participant CycleHandler as CycleSettleTaskHandler
    participant DailyCache as DailyCacheRebuildJob

    Scheduler->>ScanJob: 定时触发（每分钟）
    ScanJob->>ConfigRepo: 查询 start_time-10min 窗口赛事
    ConfigRepo-->>ScanJob: 返回候选赛事
    ScanJob->>TaskRepo: 插入 REGISTRATION_END 任务
    TaskRepo-->>ScanJob: 插入成功/已存在

    Scheduler->>DispatchJob: 定时触发（每分钟）
    DispatchJob->>DispatchSvc: dispatchPendingTasks()
    DispatchSvc->>TaskRepo: 查询 trigger_time<=now 且 PENDING/FAILED 任务
    TaskRepo-->>DispatchSvc: 返回待执行任务

    alt REGISTRATION_END 任务
        DispatchSvc->>RegHandler: execute(REGISTRATION_END)
        RegHandler->>ConfigRepo: 读取赛事配置 / 分组/补机器人
        RegHandler->>TaskRepo: 创建首个 STAGE_SETTLE 任务
        TaskRepo-->>RegHandler: TASK CREATED
        RegHandler-->>DispatchSvc: 执行完成
    end

    alt STAGE_SETTLE 任务
        DispatchSvc->>StageHandler: execute(STAGE_SETTLE)
        StageHandler->>TaskRepo: 读取挑战记录 / 更新阶段分数
        StageHandler->>TaskRepo: 创建 SEGMENT_SETTLE 任务
        StageHandler-->>DispatchSvc: 执行完成
    end

    alt SEGMENT_SETTLE 任务
        DispatchSvc->>SegmentHandler: execute(SEGMENT_SETTLE)
        SegmentHandler->>TaskRepo: 读取阶段分数 / 汇总片分
        SegmentHandler->>TaskRepo: 创建 CYCLE_SETTLE 任务
        SegmentHandler-->>DispatchSvc: 执行完成
    end

    alt CYCLE_SETTLE 任务
        DispatchSvc->>CycleHandler: execute(CYCLE_SETTLE)
        CycleHandler->>TaskRepo: 读取片分 / 汇总周期分
        CycleHandler->>TaskRepo: 更新参赛者总分
        alt 结束周期为最后周期
            CycleHandler->>TaskRepo: 触发赛事结束逻辑 / 奖励发放事件
        end
        CycleHandler-->>DispatchSvc: 执行完成
    end

    Note over DailyCache: DailyCacheRebuildJob 独立运行
    DailyCache-->>DailyCache: 触发每日缓存重建
